{
  "name": "ChatHistory",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Title of the chat conversation"
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "type": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "suggestedPlantIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "description": "Array of chat messages"
    }
  },
  "required": [
    "title",
    "messages"
  ]
}